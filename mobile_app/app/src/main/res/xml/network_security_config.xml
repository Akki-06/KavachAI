<?xml version="1.0" encoding="utf-8"?>
<!--
    Network Security Config for KavachAI
    - Cleartext (ws://) allowed ONLY for localhost and private LAN IPs
      (192.168.x.x, 10.x.x.x, 172.16.x.x) so the backend can be run locally.
    - All other traffic MUST use TLS (wss://).
    - For production deployments, remove the cleartext domains and use wss:// only.
-->
<network-security-config>

    <!-- Cleartext allowed for localhost backend development -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">localhost</domain>
        <!-- Private LAN ranges for local backend -->
        <domain includeSubdomains="true">192.168.0.0</domain>
        <domain includeSubdomains="true">10.0.0.0</domain>
        <domain includeSubdomains="true">172.16.0.0</domain>
    </domain-config>

    <!-- All other connections require TLS -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

</network-security-config>
