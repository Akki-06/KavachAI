<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Core permissions -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <!-- Required on Android 12+ to start foreground service from background on call events -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_PHONE_CALL" />
    <!-- Allows starting service even when app is not open -->
    <uses-permission android:name="android.permission.MANAGE_OWN_CALLS" />
    <!-- Re-register receiver after device reboot -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!-- End/answer calls programmatically (used to hang up scam calls) -->
    <uses-permission android:name="android.permission.ANSWER_PHONE_CALLS" />

    <application
        android:usesCleartextTraffic="true"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="KavachAI"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.KavachAI">

        <!-- Splash screen - Entry point -->
        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.KavachAI">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Onboarding and Permissions -->
        <activity
            android:name=".PermissionOnboardingActivity"
            android:exported="false"
            android:theme="@style/Theme.KavachAI" />

        <!-- Main Dashboard -->
        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:theme="@style/Theme.KavachAI" />

        <!-- Phone State Listener — high priority for reliable background delivery -->
        <receiver
            android:name=".CallReceiver"
            android:exported="true">
            <intent-filter android:priority="999">
                <action android:name="android.intent.action.PHONE_STATE" />
            </intent-filter>
        </receiver>

        <!-- Background Audio Capturing and Streaming Service -->
        <!-- phoneCall type allows starting from background on Android 12+ -->
        <service
            android:name=".CallAudioService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="microphone|phoneCall" />

    </application>

</manifest>
