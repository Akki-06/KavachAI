<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Core permissions -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <!-- Required on Android 12+ to start foreground service from background on call events -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_PHONE_CALL" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <!-- Allows starting service even when app is not open -->
    <uses-permission android:name="android.permission.MANAGE_OWN_CALLS" />
    <!-- Re-register receiver after device reboot -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!-- End/answer calls programmatically (used to hang up scam calls) -->
    <uses-permission android:name="android.permission.ANSWER_PHONE_CALLS" />
    <!-- Request battery optimization exemption so CallReceiver fires on OEM Androids -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <!-- Required for companion InCallService on Android 12+ (API 31+, normal protection level) -->
    <uses-permission android:name="android.permission.MANAGE_ONGOING_CALLS" />

    <application
        android:networkSecurityConfig="@xml/network_security_config"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="KavachAI"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.KavachAI">

        <!-- Splash screen - Entry point -->
        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.KavachAI">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Onboarding and Permissions -->
        <activity
            android:name=".PermissionOnboardingActivity"
            android:exported="false"
            android:theme="@style/Theme.KavachAI" />

        <!-- Main Dashboard -->
        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:theme="@style/Theme.KavachAI" />

        <!-- Phone State Listener — exported=false: PHONE_STATE is a protected system broadcast,
             so system still delivers it; other apps cannot send fake broadcasts to this receiver -->
        <receiver
            android:name=".CallReceiver"
            android:exported="false">
            <intent-filter android:priority="999">
                <action android:name="android.intent.action.PHONE_STATE" />
            </intent-filter>
        </receiver>

        <!-- Re-registers CallReceiver after device reboot -->
        <receiver
            android:name=".BootReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- Background Audio Capturing and Streaming Service -->
        <!-- phoneCall type allows starting from background on Android 12+ -->
        <service
            android:name=".CallAudioService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="microphone|phoneCall" />

        <!-- Companion InCallService — receives reliable call lifecycle callbacks directly
             from Android Telecom framework, bypassing OEM broadcast-blocking completely.
             IN_CALL_SERVICE_UI=false means we don't replace the user's phone app UI.
             On API 31+ requires MANAGE_ONGOING_CALLS; on API 26-30 the PHONE_STATE
             receiver acts as fallback. -->
        <service
            android:name=".KavachInCallService"
            android:permission="android.permission.BIND_INCALL_SERVICE"
            android:exported="true">
            <meta-data
                android:name="android.telecom.IN_CALL_SERVICE_UI"
                android:value="false" />
            <meta-data
                android:name="android.telecom.IN_CALL_SERVICE_RINGING"
                android:value="false" />
            <intent-filter>
                <action android:name="android.telecom.InCallService" />
            </intent-filter>
        </service>

        <!-- Persistent watchdog — keeps process alive on OEM Androids so
             CallReceiver fires immediately when any call comes in -->
        <service
            android:name=".KavachWatchdogService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="specialUse"
            android:stopWithTask="false" />

    </application>

</manifest>
